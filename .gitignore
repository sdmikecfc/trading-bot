# ============================================================
# SECURITY: Never commit your .env file.
# It contains your private key or mnemonic — anyone who gets
# this file can drain your wallet instantly.
# ============================================================
.env

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pdb

# Virtual environments
venv/
.venv/
env/
.env/

# Distribution / packaging
dist/
build/
*.egg-info/

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Claude Code internal files
.claude/

# Runtime state files — contain position/trade data, never commit
positions.json
scheduled_snipes.json
seen_tokens.json
tokens.json

# Encrypted wallet keystore — contains your encrypted private key, never commit
keystore.json
