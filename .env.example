# ============================================================
#  Doma Protocol Sniper Bot — Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit your .env file — it contains your private key.
# ============================================================


# ── Wallet (choose ONE) ──────────────────────────────────────
#
# Option A: 12/24-word seed phrase
# MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
#
# Option B: Raw private key (with or without 0x prefix)
# PRIVATE_KEY=0xYourPrivateKeyHere
#
# If using a mnemonic with multiple accounts, set the index (default 0 = first account)
# MNEMONIC_ACCOUNT_INDEX=0


# ── Network (Doma chain — defaults are correct, no need to change) ────────────
RPC_URL=https://rpc.doma.xyz
CHAIN_ID=97477
USDCE_ADDRESS=0x31EEf89D5215C305304a2fA5376a1f1b6C5dc477
ROUTER_ADDRESS=0x5089863E97196773038f98459262D866f2281f58


# ── Doma API (public key — no need to change) ─────────────────────────────────
DOMA_API_KEY=v1.c6e3f41019fb97237b7f192d49adb2ae464f2ba7ca6c0737fd6eab71ee01d1d4


# ── Sniper settings ───────────────────────────────────────────────────────────

# Amount of USDC.e to spend per snipe
SNIPE_AMOUNT_USD=1.00

# Maximum total spend per UTC day across all auto-snipes
SNIPE_DAILY_LIMIT=20.00

# Only snipe tokens where Starting FDV is at or below this value (USD)
# Set to 999999 to snipe all FDV ranges
SNIPE_MAX_INITIAL_FDV=500

# Minimum ratio of Bonding FDV to Starting FDV required to snipe
# 1.5 = bonding curve must be at least 1.5x the starting price
SNIPE_MIN_SPREAD=1.1

# DRY RUN — set to false when ready to trade real funds
# true  = logs actions but never sends transactions
# false = executes real on-chain transactions
DRY_RUN=true


# ── Tiered exit strategy (schedule_sniper.py only) ────────────────────────────
# Sells TRANCHE_SELL_PCT% of your position at each price multiplier on the bonding curve.
# The final tranche (25%) is held as a moon bag through graduation.

TRANCHE_SELL_PCT=25
TRANCHE_1_MULT=1.5
TRANCHE_2_MULT=2.0
TRANCHE_3_MULT=3.0
POSITION_POLL_SEC=30
GRADUATION_SELL_PERCENT=75


# ── Schedule sniper settings (schedule_sniper.py only) ───────────────────────

# Google Sheet CSV URL — public schedule (no need to change)
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/1p5TvCYo7ZQvCkSyxPJWor_GIrRCu-5l1RRMCEv3THm0/export?format=csv

# How often to re-read the sheet (minutes)
SHEET_REFRESH_MIN=5

# How many seconds before launch to start tight-polling the API
PRELOAD_SEC=120

# How often to poll during the tight window (seconds)
POLL_TIGHT_SEC=3
