# ============================================================
# DOMA BOT CONFIGURATION
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains your private key.
# ============================================================

# ── Wallet (use ONE method — comment out the other) ─────────
MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
# PRIVATE_KEY=0xYourRawPrivateKeyHere

# Which account index to derive from mnemonic (0 = first account)
MNEMONIC_ACCOUNT_INDEX=0

# ── Network ─────────────────────────────────────────────────
RPC_URL=https://rpc.doma.xyz
CHAIN_ID=97477

# ── Fixed addresses (same for all tokens — do not change) ───
USDCE_ADDRESS=0x31EEf89D5215C305304a2fA5376a1f1b6C5dc477
ROUTER_ADDRESS=0x5089863E97196773038f98459262D866f2281f58

# ── Doma API (used to auto-discover all tokens) ─────────────
DOMA_API_KEY=v1.c6e3f41019fb97237b7f192d49adb2ae464f2ba7ca6c0737fd6eab71ee01d1d4

# ── Trade settings ──────────────────────────────────────────
TRADE_MIN_USD=0.10
TRADE_MAX_USD=0.30
INTERVAL_MIN_SEC=60
INTERVAL_MAX_SEC=300
SLIPPAGE_PERCENT=2.0

# ── Buy/sell bias ───────────────────────────────────────────
BUY_WEIGHT=65
SELL_WEIGHT=35

# ── Daily cap ───────────────────────────────────────────────
DAILY_LOSS_LIMIT_USD=10.0
MIN_ETH_FOR_GAS=0.001

# ── Token list refresh ──────────────────────────────────────
# How often (in cycles) to re-fetch the token list from the API.
# 50 cycles = roughly every 2-4 hours depending on your interval.
TOKEN_REFRESH_CYCLES=50

# ── Sniper settings ─────────────────────────────────────────
# Amount of USDC.e to spend per snipe
SNIPE_AMOUNT_USD=1.00

# Max total USDC.e spent on sniping per UTC day
SNIPE_DAILY_LIMIT=20.00

# Only snipe tokens with initialFDV at or below this (low FDV = low BIN = 95% grad rate)
SNIPE_MAX_INITIAL_FDV=500

# bondingFDV must be at least this multiple of initialFDV (profit spread requirement)
SNIPE_MIN_SPREAD=1.5

# Sell this % of sniped position immediately after graduation. Rest continues to be held.
GRADUATION_SELL_PERCENT=75

# How many seconds between snipe scans
SNIPE_POLL_SEC=60

# ── Mode ────────────────────────────────────────────────────
# true = simulate only, no real transactions. Always start here.
DRY_RUN=true
