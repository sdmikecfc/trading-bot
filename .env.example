# ============================================================
# DOMA BOT CONFIGURATION
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains your private key.
# ============================================================

# ── Wallet (use ONE method — comment out the other) ─────────
MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
# PRIVATE_KEY=0xYourRawPrivateKeyHere

# Which account index to derive from mnemonic (0 = first account)
MNEMONIC_ACCOUNT_INDEX=0

# ── Network ─────────────────────────────────────────────────
RPC_URL=https://rpc.doma.xyz
CHAIN_ID=97477

# ── Token addresses (fill in per token you want to trade) ───
TOKEN_ADDRESS=0xYourTokenContractAddress
USDCE_ADDRESS=0x31EEf89D5215C305304a2fA5376a1f1b6C5dc477
POOL_ADDRESS=0xYourUniswapV3PoolAddress
ROUTER_ADDRESS=0x5089863E97196773038f98459262D866f2281f58

# ── Trade settings ──────────────────────────────────────────
TRADE_MIN_USD=0.10
TRADE_MAX_USD=0.30
INTERVAL_MIN_SEC=60
INTERVAL_MAX_SEC=300
SLIPPAGE_PERCENT=2.0

# ── Buy/sell bias ───────────────────────────────────────────
# These are relative weights. 65+35=100 means ~65% buys, ~35% sells.
BUY_WEIGHT=65
SELL_WEIGHT=35

# ── Price floor ─────────────────────────────────────────────
# Bot switches to buy-only if price drops below this (in USD).
# Set to ~20% below current price. Use 0.0 to disable.
PRICE_FLOOR_USD=0.0

# ── Daily cap ───────────────────────────────────────────────
# Hard cap on gross USDC.e spent buying per UTC day.
DAILY_LOSS_LIMIT_USD=10.0

# Minimum ETH to keep for gas. Bot skips trades if below this.
MIN_ETH_FOR_GAS=0.001

# ── Mode ────────────────────────────────────────────────────
# true = simulate only, no real transactions. Always start here.
DRY_RUN=true
